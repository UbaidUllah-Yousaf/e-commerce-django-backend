# Copy to `.env` and adjust. Used by Django settings for PostgreSQL.
POSTGRES_DB=ecommerce
POSTGRES_USER=ubaid
POSTGRES_PASSWORD=Ubaid@123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional: connection pool age in seconds (default 60 in settings)
# POSTGRES_CONN_MAX_AGE=60

# Set to 1 only for local tests without PostgreSQL (uses SQLite).
# DJANGO_USE_SQLITE=0

# Optional: storefront order display (Shopify-style name / sequential number).
# ECOMMERCE_ORDER_NAME_PREFIX=#
# ECOMMERCE_FIRST_ORDER_NUMBER=1000

# React + Vite storefront (used to generate Stripe success/cancel redirect URLs)
# STOREFRONT_BASE_URL=http://localhost:5173
# STOREFRONT_CHECKOUT_SUCCESS_PATH=/checkout/success
# STOREFRONT_CHECKOUT_CANCEL_PATH=/checkout/cancel

# Stripe Checkout (https://dashboard.stripe.com/test/apikeys)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from `stripe listen` or Dashboard → Webhooks

# Logistics / Quiqup / Celery (Shopify credentials are Django admin only)
# Load demo config: python manage.py seed_logistics
REDIS_URL=redis://localhost:6379/0
QUIQUP_USE_MOCK=1
# Optional HTTP mock (Celery uses in-process mock when QUIQUP_USE_MOCK=1):
# QUIQUP_BASE_URL=http://127.0.0.1:8000/api/v1/logistics/mock/quiqup
# QUIQUP_API_KEY=ak_Q4NHNWSS21Z8858T2CXQX5Y5GC253W0K
# QUIQUP_BASE_URL=https://platform-api.staging.quiqup.com
# QUIQUP_CLIENT_ID=
# QUIQUP_CLIENT_SECRET=
# LOGISTICS_QUIQUP_POLL_MINUTES=15
